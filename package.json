{
	"name": "limbo",
	"author": "Jaxson Sprinkles",
	"version": "1.0.3",
	"description": "Ephemeral file management for Windows and macOS",
	"main": "dist/electron/main.js",
	"scripts": {
		"dev": "vite",
		"build": "tsc -p tsconfig.node.json && vite build && electron-builder --win",
		"build:mac": "tsc -p tsconfig.node.json && vite build && electron-builder --mac",
		"build:renderer": "vite build",
		"build:electron": "tsc -p tsconfig.node.json",
		"preview": "vite preview"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.0.0",
		"chokidar": "^3.6.0",
		"electron-store": "^8.2.0",
		"lucide-react": "^1.11.0",
		"mime-types": "^2.1.35",
		"mona-sans": "^1.0.0",
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"react-router-dom": "^6.23.0",
		"zustand": "^4.5.0"
	},
	"devDependencies": {
		"@types/mime-types": "^2.1.4",
		"@types/node": "^20.12.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.2.0",
		"autoprefixer": "^10.4.0",
		"concurrently": "^8.2.0",
		"electron": "^29.0.0",
		"electron-builder": "^24.13.0",
		"postcss": "^8.4.0",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.4.0",
		"vite": "^5.2.0",
		"vite-plugin-electron": "^0.28.0",
		"vite-plugin-electron-renderer": "^0.14.0",
		"wait-on": "^7.2.0"
	},
	"build": {
		"appId": "com.limbo.app",
		"productName": "Limbo",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/electron/**/*",
			"dist/renderer/**/*",
			"resources/**/*"
		],
		"win": {
			"target": "nsis",
			"icon": "resources/icons/icon.ico"
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"icon": "resources/icons/icon.png",
			"category": "public.app-category.productivity"
		},
		"dmg": {
			"title": "Limbo",
			"background": null,
			"contents": [
				{
					"x": 130,
					"y": 220,
					"type": "file"
				},
				{
					"x": 410,
					"y": 220,
					"type": "link",
					"path": "/Applications"
				}
			]
		},
		"extraResources": [
			{
				"from": "resources/icons",
				"to": "icons"
			}
		]
	}
}
